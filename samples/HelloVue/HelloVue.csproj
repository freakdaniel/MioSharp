<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\..\src\Mio.App\Mio.App.csproj" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <!-- Build Vue app with Vite (requires Node.js + npm) -->
  <Target Name="BuildVueApp" BeforeTargets="Build"
          Condition="Exists('$(ProjectDir)src/package.json')">
    <Exec Command="npm install"
          WorkingDirectory="$(ProjectDir)src"
          Condition="!Exists('$(ProjectDir)src/node_modules')"/>
    <Exec Command="npm run build" WorkingDirectory="$(ProjectDir)src"/>
  </Target>

</Project>
